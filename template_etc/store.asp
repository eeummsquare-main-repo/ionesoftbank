	positions.forEach(function(addr, i) {
		var juso = positions[i].latlng;

		geocoder.addressSearch(addr.latlng, function(result, status) {
			// 정상적으로 검색이 완료됐으면
			if (status === kakao.maps.services.Status.OK) {
				var coords = new kakao.maps.LatLng(result[0].y, result[0].x);

				//$(".storeMap_list a.link").eq([i]).attr({"data-codes-lat": coords.getLat(), "data-codes-lng": coords.getLng()})

				var markers = $(coords).map(function(i, position) {
					return new kakao.maps.Marker({
						position : coords
					});
				});

				var contentStr = '<div class="customoverlay"><a href="javascript:storeFancy('+addr.num+');" class="coBox"><span class="title">'+addr.title+'</span></a></div>';
				var customOverlay = new kakao.maps.CustomOverlay({
					map: map,
					content: contentStr,
					position: coords,
					yAnchor: 1
				});

				bounds.extend(coords);

				clusterer.addMarkers(markers);

				daum.maps.event.addListener(map, 'zoom_changed', function() {
					var currentLevel = map.getLevel();
					//console.log(currentLevel)
					// 레벨이 9 이상인 경우 CustomOverlay를 숨깁니다.
					if (currentLevel > 9) {
						customOverlay.setMap(null);
					} else {
						customOverlay.setMap(map);
					}
				});

				bounds.extend(coords);
			}
		});
	})

	map.setBounds(bounds, 90, 30, 10, 30);

	$(window).on('throttledresize', function(){// Resize Event
		setTimeout(function(){
			map.setBounds(bounds, 90, 30, 10, 30);
		}, 10);
	}).resize();
</script>
<script type="text/javascript">
	$(function () {
		$("body").on("click", ".storeMap_list .link", function(){
			var idx = $(".storeMap_list .link").index($(this));
			var juso = positions[idx].latlng;

			$(".storeMap_list .link").removeClass("open");


			$(".storeMap_list .link").eq(idx).addClass("open");

			//console.log(idx, juso)
			geocoder.addressSearch(juso, function(result, status) {
				// 정상적으로 검색이 완료됐으면
				if (status === kakao.maps.services.Status.OK) {
					var coords = new kakao.maps.LatLng(result[0].y, result[0].x);

					map.setLevel(4);
					map.panTo(coords);
				}
			});
		});
	});

	function storeFancy(num){
		num = num -1;
		$(".storeFancyLay .store_info .subject").html(positions[num].title);
		$(".storeFancyLay .store_info .addr").html(positions[num].latlng);
		$(".storeFancyLay .store_info .tel").html(positions[num].tel);
		$(".storeFancyLay .store_info .time").html(positions[num].time);
		$(".storeFancyLay .right_box").html('<img src="'+positions[num].img+'" alt="'+positions[num].title+'">');

		new Fancybox(
			[{src:"#storeFancyLay", type: "inline"},],
			{
				on: {
					"*": (event, fancybox, slide) => {
						console.log(`event: ${event}`);

						if(event == "ready"){
							var juso = positions[num].latlng;
							var mapContainer = document.getElementById("storeLayMap"), // 지도의 중심좌표
								mapOption = {
									center: new daum.maps.LatLng(37.4010148291019, 126.991355744449), // 지도의 중심좌표
									level: 2 // 지도의 확대 레벨
								};
							var map = new daum.maps.Map(mapContainer, mapOption); // 지도를 생성합니다

							map.setZoomable(false);

							var geocoder = new kakao.maps.services.Geocoder();
							geocoder.addressSearch(juso, function(result, status) {
								// 정상적으로 검색이 완료됐으면
								if (status === kakao.maps.services.Status.OK) {
									var coords = new kakao.maps.LatLng(result[0].y, result[0].x);

									// 지도 확대 축소를 제어할 수 있는  줌 컨트롤을 생성합니다
									var zoomControl = new daum.maps.ZoomControl();
									map.addControl(zoomControl, daum.maps.ControlPosition.RIGHT);

									var bounds = new kakao.maps.LatLngBounds();

									// 지도에 마커를 표시합니다
									var marker = new daum.maps.Marker({
										map: map,
										position: coords
									});

									var contentStr = "<div class='customoverlay'><p class='coBox'><span class='title'>"+positions[num].title+"</span></p></div>";
									var overlay = new kakao.maps.CustomOverlay({
										map: map,
										position: coords,
										content: contentStr,
										yAnchor: 1
									});


									bounds.extend(coords);

									$(window).on('throttledresize', function(){// Resize Event
										setTimeout(function(){
											map.setBounds(bounds, 30, 30, 10, 30);
										}, 10);
									}).resize();
								}
							});
						}

						if(event == "closing"){
							$(".storeFancyLay .store_info .subject").html("");
							$(".storeFancyLay .store_info .addr").html("");
							$(".storeFancyLay .store_info .tel").html("");
							$(".storeFancyLay .store_info .time").html("");
							$(".storeFancyLay .storeFancy_thumb").html("");
						}
					},
				},
			}
		);
	}
</script>
