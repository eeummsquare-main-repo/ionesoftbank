			img:"/images/img_shop_view.jpg"
		},
		{
			num: '2',
			area:"서울특별시",
			title: '청담 삼성점',
			tel: '02-540-3705',
			latlng: "서울시 강남구 삼성로 119길 8, 2층",
			time: "(평일) 10:32 - 21:00<br />(주말) 10:30 - 22:00",
			img:"/images/main/img_mVisual01.jpg"
		},
		{
			num: '3',
			area:"서울특별시",
			title: '인천 검단점',
			tel: '032-567-3705',
			latlng: "인천시 서구 원당대로 638 1동 201호",
			time: "(평일) 10:33 - 21:00<br />(주말) 10:30 - 22:00",
			img:"/images/main/img_mVisual02.jpg"
		},
		{
			num: '4',
			area:"서울특별시",
			title: '서래마을점',
			tel: '02-593-3705',
			latlng: "서울시 서초구 서래로 7길 16(민트빌딩 2층)",
			time: "(평일) 10:34 - 21:00<br />(주말) 10:30 - 22:00",
			img:"/images/main/img_mConts01.jpg"
		},
		{
			num: '5',
			area:"서울특별시",
			title: '광진점',
			tel: '02-453-3705',
			latlng: "서울시 광진구 아차산로 76가길 5 1층",
			time: "(평일) 10:35 - 21:00<br />(주말) 10:30 - 22:00",
			img:"/images/main/img_mConts02.jpg"
		},
		{
			num: '6',
			area:"서울특별시",
			title: '목동점',
			tel: '02-2644-3705',
			latlng: "서울시 양천구 목동동로 309 행복한백화점 1층",
			time: "(평일) 10:36 - 21:00<br />(주말) 10:30 - 22:00",
